#include <iostream>
using namespace std;

class Book {
private:
    string title, author, ISBN, dateAdd;
    bool available;

public:
    void setBookDetails(string t, string a, string i, string d) {
        title = t;
        author = a;
        ISBN = i;
        dateAdd = d;
        available = true;
    }

    void displayBookDetails() {
        cout << "Title: " << title << endl;
        cout << "Author: " << author << endl;
        cout << "ISBN: " << ISBN << endl;
        cout << "Available: " << (available ? "Yes" : "No") << endl;
        cout << "------------------------" << endl;
    }

    void borrowBook() {
        if (available) {
            available = false;
            cout << "Book borrowed successfully.\n";
        } else {
            cout << "Book is not available.\n";
        }
    }

    void returnBook() {
        available = true;
        cout << "Book returned successfully.\n";
    }

    string getISBN() {
        return ISBN;
    }
};
